# TinyIoTHub 部署环境变量
# 复制此文件为 .env 并修改配置

# Anthropic API Key（ZeroClaw AI Agent 需要）
ANTHROPIC_API_KEY=sk-ant-xxx

# ZeroClaw 配置
ZEROCLAW_PROVIDER=anthropic

# 运行用户 UID/GID（与宿主机一致）
UID=1000
GID=1000

# JWT 密钥（生产环境必须修改，至少 32 字符）
# 生成方式: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# MQTT 凭据
MQTT_USERNAME=admin
MQTT_PASSWORD=change-me
