    {"name": "ptz_move", "display_name": { "zh": "PTZ移动", "en": "PTZ Move" }, "description": { "zh": "控制云台移动", "en": "Control PTZ movement" }, "parameters": "{\"direction\": \"left\"}", "parameter_schema": "{\"type\": \"object\", \"properties\": {\"direction\": {\"type\": \"string\", \"enum\": [\"left\", \"right\", \"up\", \"down\", \"stop\"]}}, \"required\": [\"direction\"]}", "is_required": false},
    {"name": "ptz_home", "display_name": { "zh": "回到原点", "en": "PTZ Home" }, "description": { "zh": "云台回到初始位置", "en": "Move PTZ to home position" }, "parameters": "{}", "is_required": false}
  ]
