    {"name": "ptz_tilt", "display_name": { "zh": "俯仰角度", "en": "Tilt Angle" }, "description": { "zh": "PTZ俯仰角度", "en": "PTZ tilt angle" }, "data_type": "number", "unit": "°", "min_value": -90.0, "max_value": 90.0, "default_value": "0", "is_read_only": false, "is_required": false}
