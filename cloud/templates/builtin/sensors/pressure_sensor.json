{
  "name": "pressure_sensor",
  "display_name": {
    "zh": "压力传感器",
    "en": "Pressure Sensor"
  },
  "description": {
    "zh": "标准压力传感器设备模板，支持压力监测和报警配置",
    "en": "Standard pressure sensor device template with pressure monitoring and alarm configuration"
  },
  "version": "1.0.0",
  "author": "System",
  "category": "sensors",
  "manufacturer": null,
  "device_type": "sensor",
  "protocol_type": "modbus",
  "driver_name": "modbus_rtu",
  "tags": ["sensor", "pressure", "monitoring"],
  "device_info": {
    "default_name_pattern": "pressure_sensor_{index}",
    "default_display_name_pattern": "压力传感器 {index}",
    "default_description": {
      "zh": "压力监测传感器",
      "en": "Pressure monitoring sensor"
    },
    "required_fields": ["name", "address"]
  },
  "properties": [
    {
      "name": "pressure",
      "display_name": {
        "zh": "压力",
        "en": "Pressure"
      },
      "description": {
        "zh": "当前环境压力",
        "en": "Current ambient pressure"
      },
      "data_type": "number",
      "unit": "kPa",
      "min_value": 0.0,
      "max_value": 1000.0,
      "default_value": "101.3",
      "is_read_only": true,
      "is_required": true
    },
    {
      "name": "alarm_high_pressure",
      "display_name": {
        "zh": "高压报警阈值",
        "en": "High Pressure Alarm Threshold"
      },
      "description": {
        "zh": "压力超过此值时触发报警",
        "en": "Trigger alarm when pressure exceeds this value"
      },
      "data_type": "number",
      "unit": "kPa",
      "min_value": 0.0,
      "max_value": 1000.0,
      "default_value": "200.0",
      "is_read_only": false,
      "is_required": false
    },
    {
      "name": "alarm_low_pressure",
      "display_name": {
        "zh": "低压报警阈值",
        "en": "Low Pressure Alarm Threshold"
      },
      "description": {
        "zh": "压力低于此值时触发报警",
        "en": "Trigger alarm when pressure below this value"
      },
      "data_type": "number",
      "unit": "kPa",
      "min_value": 0.0,
      "max_value": 1000.0,
      "default_value": "50.0",
      "is_read_only": false,
      "is_required": false
    },
    {
      "name": "sampling_interval",
      "display_name": {
        "zh": "采样间隔",
        "en": "Sampling Interval"
      },
      "description": {
        "zh": "数据采样时间间隔",
        "en": "Data sampling time interval"
      },
      "data_type": "number",
      "unit": "秒",
      "min_value": 1.0,
      "max_value": 3600.0,
      "default_value": "60.0",
      "is_read_only": false,
      "is_required": false
    }
  ],
  "commands": [
    {
      "name": "read_pressure",
      "display_name": {
        "zh": "读取压力",
        "en": "Read Pressure"
      },
      "description": {
        "zh": "读取当前压力值",
        "en": "Read current pressure value"
      },
      "parameters": "{}",
      "is_required": true
    },
    {
      "name": "set_alarm_thresholds",
      "display_name": {
        "zh": "设置报警阈值",
        "en": "Set Alarm Thresholds"
      },
      "description": {
        "zh": "设置高低压报警阈值",
        "en": "Set high and low pressure alarm thresholds"
      },
      "parameters": "{\"high_pressure\": 200, \"low_pressure\": 50}",
      "parameter_schema": "{\"type\": \"object\", \"properties\": {\"high_pressure\": {\"type\": \"number\", \"minimum\": 0, \"maximum\": 1000}, \"low_pressure\": {\"type\": \"number\", \"minimum\": 0, \"maximum\": 1000}}, \"required\": [\"high_pressure\", \"low_pressure\"]}",
      "is_required": false
    },
    {
      "name": "calibrate_sensor",
      "display_name": {
        "zh": "校准传感器",
        "en": "Calibrate Sensor"
      },
      "description": {
        "zh": "执行传感器校准程序",
        "en": "Execute sensor calibration procedure"
      },
      "parameters": "{\"reference_pressure\": 101.3}",
      "parameter_schema": "{\"type\": \"object\", \"properties\": {\"reference_pressure\": {\"type\": \"number\", \"minimum\": 0, \"maximum\": 1000}}, \"required\": [\"reference_pressure\"]}",
      "is_required": false
    },
    {
      "name": "zero_calibration",
      "display_name": {
        "zh": "零点校准",
        "en": "Zero Calibration"
      },
      "description": {
        "zh": "执行压力传感器零点校准",
        "en": "Execute pressure sensor zero point calibration"
      },
      "parameters": "{}",
      "is_required": false
    }
  ]
}