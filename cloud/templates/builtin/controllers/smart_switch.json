      "parameters": "{}",
      "is_required": true
    },
    {
      "name": "turn_off",
      "display_name": {
        "zh": "关闭",
        "en": "Turn Off"
      },
      "description": {
        "zh": "关闭开关",
        "en": "Turn off the switch"
      },
      "parameters": "{}",
      "is_required": true
    },
    {
      "name": "toggle",
      "display_name": {
        "zh": "切换",
        "en": "Toggle"
      },
      "description": {
        "zh": "切换开关状态",
