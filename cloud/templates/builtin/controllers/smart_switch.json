        "zh": "设置定时开关",
        "en": "Set timer for switch operation"
      },
      "parameters": "{\"action\": \"on\", \"delay_seconds\": 3600}",
      "parameter_schema": "{\"type\": \"object\", \"properties\": {\"action\": {\"type\": \"string\", \"enum\": [\"on\", \"off\", \"toggle\"]}, \"delay_seconds\": {\"type\": \"number\", \"minimum\": 1, \"maximum\": 86400}}, \"required\": [\"action\", \"delay_seconds\"]}",
      "is_required": false
    },
    {
      "name": "get_power_stats",
      "display_name": {
        "zh": "获取电量统计",
        "en": "Get Power Statistics"
      },
      "description": {
        "zh": "获取电量使用统计信息",
        "en": "Get power usage statistics"
      },
      "parameters": "{}",
      "is_required": false
    },
    {
      "name": "reset_energy_counter",
      "display_name": {
        "zh": "重置电量计数",
        "en": "Reset Energy Counter"
      },
      "description": {
        "zh": "重置累计用电量计数器",
        "en": "Reset accumulated energy counter"
      },
      "parameters": "{}",
      "is_required": false
    },
    {
      "name": "get_device_info",
      "display_name": {
        "zh": "获取设备信息",
        "en": "Get Device Info"
      },
      "description": {
        "zh": "获取设备基本信息和状态",
        "en": "Get device basic information and status"
      },
      "parameters": "{}",
      "is_required": false
    }
  ]
