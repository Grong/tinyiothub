# TinyIoTHub 环境变量配置

# MQTT 主连接
MQTT_PRIMARY_HOST=192.168.1.124
MQTT_PRIMARY_PORT=1883
MQTT_PRIMARY_USERNAME=admin
MQTT_PRIMARY_PASSWORD=your_secure_password_here

# MQTT 备用连接
MQTT_SECONDARY_HOST=175.178.49.5
MQTT_SECONDARY_PORT=9990
MQTT_SECONDARY_USERNAME=admin
MQTT_SECONDARY_PASSWORD=your_secure_password_here

# JWT 配置
JWT_SECRET=your-very-secure-jwt-secret-key-at-least-32-characters-long-change-this
JWT_EXPIRATION_SECS=10800

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=3002

# 数据库
DATABASE_URL=tinyiothub.db

# 日志
RUST_LOG=info
LOG_FILE_PATH=logs/app.log

# 环境
ENVIRONMENT=production

# 网络默认值（可选，用于测试和开发）
DEFAULT_IP_ADDRESS=0.0.0.0
MQTT_DEFAULT_HOST=localhost
MQTT_SECONDARY_HOST=localhost
TEST_DEVICE_ADDRESS=127.0.0.1

# CORS 允许的来源（JSON 数组格式）
TINYIOTHUB__SERVER__CORS_ORIGINS=["https://tinyiothub.com","https://www.tinyiothub.com","https://api.tinyiothub.com"]

# 阿里云 SMS
SMS_ALIYUN_ACCESS_KEY_ID=your_access_key_id
SMS_ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
SMS_ALIYUN_SIGN_NAME=您的签名
SMS_ALIYUN_TEMPLATE_CODE=SMS_xxxxx

# 腾讯防水墙
SMS_CAPTCHA_APP_ID=your_app_id
SMS_CAPTCHA_APP_SECRET=your_app_secret

# 微信开放平台
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_REDIRECT_URI=https://yourdomain.com/auth/wechat/callback

# Redis（用于会话和频率限制）
REDIS_URL=redis://localhost:6379

# HarmonyOS specific
HARMONYOS_MODE=  # Set to any value to enable HarmonyOS mode (uses OpenSSL instead of ring-based crypto)
