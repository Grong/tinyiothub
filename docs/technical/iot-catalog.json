{
  "catalog": "iot",
  "version": "1.0.0",
  "extends": "basic",
  "metadata": {
    "name": "TinyIoTHub IoT Catalog",
    "description": "Domain-specific components for IoT device management, extending A2UI Basic Catalog v0.10",
    "author": "TinyIoTHub",
    "date": "2026-04-03",
    "license": "MIT"
  },
  "components": [
    {
      "id": "DeviceCard",
      "name": "Device Card",
      "description": "Single device display card showing device status, key metrics, and quick actions. Suitable for dashboard grids and device lists.",
      "category": "display",
      "properties": {
        "deviceId": {
          "type": "string",
          "required": true,
          "description": "Unique device identifier"
        },
        "name": {
          "type": "string",
          "required": true,
          "description": "Device display name"
        },
        "status": {
          "type": "enum",
          "required": true,
          "values": ["online", "offline", "warning", "error"],
          "description": "Device operational status"
        },
        "deviceType": {
          "type": "string",
          "required": false,
          "default": "generic",
          "description": "Device type (sensor, actuator, gateway, controller)"
        },
        "protocol": {
          "type": "string",
          "required": false,
          "description": "Protocol name (modbus, onvif, snmp, mqtt)"
        },
        "lastSeen": {
          "type": "string",
          "required": false,
          "format": "iso8601",
          "description": "ISO 8601 timestamp of last heartbeat"
        },
        "properties": {
          "type": "array",
          "required": false,
          "default": [],
          "items": {
            "name": "string",
            "value": "string",
            "unit": "string",
            "displayName": "string"
          },
          "description": "Current property values array"
        },
        "showActions": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Show action buttons"
        },
        "compact": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Compact card variant"
        },
        "icon": {
          "type": "string",
          "required": false,
          "description": "Device icon identifier"
        },
        "selected": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Selected state for multi-select"
        }
      },
      "events": {
        "onClick": {
          "payload": "{ deviceId: string, name: string }",
          "description": "Card clicked - expand details"
        },
        "onCommand": {
          "payload": "{ deviceId: string, command: string }",
          "description": "Quick command executed"
        },
        "onRefresh": {
          "payload": "{ deviceId: string }",
          "description": "Refresh device data"
        },
        "onNavigate": {
          "payload": "{ deviceId: string, target: string }",
          "description": "Navigate to device detail"
        },
        "onSelect": {
          "payload": "{ deviceId: string, selected: boolean }",
          "description": "Card selection changed"
        }
      },
      "dataBinding": {
        "type": "DeviceCardData",
        "schema": {
          "device": {
            "id": "string",
            "name": "string",
            "displayName": "string?",
            "deviceType": "string",
            "protocolType": "string",
            "state": "0 | 1 | 2 | 3",
            "lastHeartbeat": "string?",
            "properties": "DeviceProperty[]?"
          },
          "ui": {
            "showActions": "boolean?",
            "compact": "boolean?",
            "selected": "boolean?"
          }
        }
      },
      "examples": [
        {
          "title": "Online Sensor Device",
          "json": {
            "type": "updateComponents",
            "payload": {
              "surfaceId": "device-dashboard",
              "components": [
                {
                  "id": "card-001",
                  "type": "DeviceCard",
                  "props": {
                    "deviceId": "dev-abc123",
                    "name": "Temperature Sensor A1",
                    "status": "online",
                    "deviceType": "sensor",
                    "protocol": "modbus",
                    "lastSeen": "2026-04-03T10:30:00Z",
                    "properties": [
                      { "name": "temperature", "value": "25.6", "unit": "C" },
                      { "name": "humidity", "value": "65", "unit": "%" }
                    ],
                    "showActions": true,
                    "compact": false
                  }
                }
              ]
            }
          }
        },
        {
          "title": "Offline Device (Compact)",
          "json": {
            "type": "updateComponents",
            "payload": {
              "surfaceId": "device-dashboard",
              "components": [
                {
                  "id": "card-002",
                  "type": "DeviceCard",
                  "props": {
                    "deviceId": "dev-def456",
                    "name": "Gateway B2",
                    "status": "offline",
                    "deviceType": "gateway",
                    "protocol": "mqtt",
                    "lastSeen": "2026-04-03T02:15:00Z",
                    "showActions": false,
                    "compact": true
                  }
                }
              ]
            }
          }
        }
      ]
    },
    {
      "id": "DeviceTable",
      "name": "Device Table",
      "description": "Multi-device list view with sortable columns, row selection, and pagination. Suitable for device management pages.",
      "category": "display",
      "properties": {
        "devices": {
          "type": "array",
          "required": true,
          "items": {
            "id": "string",
            "name": "string",
            "displayName": "string?",
            "deviceType": "string",
            "protocolType": "string",
            "state": "0 | 1 | 2 | 3",
            "lastHeartbeat": "string?",
            "createdAt": "string?"
          },
          "description": "Array of device objects"
        },
        "columns": {
          "type": "array",
          "required": false,
          "default": "default",
          "items": {
            "id": "string",
            "label": "string",
            "sortable": "boolean?",
            "width": "string?",
            "align": "string?",
            "format": "string?"
          },
          "description": "Column configuration"
        },
        "sortColumn": {
          "type": "string",
          "required": false,
          "default": "name",
          "description": "Default sort column"
        },
        "sortOrder": {
          "type": "enum",
          "required": false,
          "values": ["asc", "desc"],
          "default": "asc",
          "description": "Sort direction"
        },
        "page": {
          "type": "number",
          "required": false,
          "default": 1,
          "description": "Current page"
        },
        "pageSize": {
          "type": "number",
          "required": false,
          "default": 10,
          "description": "Items per page"
        },
        "total": {
          "type": "number",
          "required": false,
          "default": 0,
          "description": "Total item count"
        },
        "selectable": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Enable row selection"
        },
        "selectionMode": {
          "type": "enum",
          "required": false,
          "values": ["single", "multi", "none"],
          "default": "single",
          "description": "Selection mode"
        },
        "selectedIds": {
          "type": "array",
          "required": false,
          "default": [],
          "description": "Pre-selected device IDs"
        },
        "emptyMessage": {
          "type": "string",
          "required": false,
          "description": "Message when no data"
        },
        "loading": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Loading state"
        }
      },
      "events": {
        "onSort": {
          "payload": "{ column: string, order: 'asc' | 'desc' }",
          "description": "Sort changed"
        },
        "onPage": {
          "payload": "{ page: number, pageSize: number }",
          "description": "Pagination changed"
        },
        "onSelect": {
          "payload": "{ selectedIds: string[] }",
          "description": "Selection changed"
        },
        "onRowClick": {
          "payload": "{ deviceId: string, device: object }",
          "description": "Row clicked"
        },
        "onAction": {
          "payload": "{ deviceId: string, action: string }",
          "description": "Row action triggered"
        }
      },
      "dataBinding": {
        "type": "DeviceTableData",
        "schema": {
          "devices": "Device[]",
          "pagination": {
            "page": "number",
            "pageSize": "number",
            "total": "number",
            "totalPages": "number"
          },
          "selection": {
            "mode": "'single' | 'multi' | 'none'",
            "selectedIds": "string[]"
          }
        }
      },
      "examples": [
        {
          "title": "Multi-device List with Selection",
          "json": {
            "type": "updateComponents",
            "payload": {
              "surfaceId": "device-list",
              "components": [
                {
                  "id": "table-001",
                  "type": "DeviceTable",
                  "props": {
                    "devices": [
                      {
                        "id": "dev-001",
                        "name": "Sensor-001",
                        "displayName": "Temperature Sensor 1",
                        "deviceType": "sensor",
                        "protocolType": "modbus",
                        "state": 1,
                        "lastHeartbeat": "2026-04-03T10:30:00Z"
                      },
                      {
                        "id": "dev-002",
                        "name": "Actuator-001",
                        "displayName": "Valve Controller",
                        "deviceType": "actuator",
                        "protocolType": "mqtt",
                        "state": 1,
                        "lastHeartbeat": "2026-04-03T10:29:45Z"
                      }
                    ],
                    "columns": [
                      { "id": "name", "label": "Name", "sortable": true },
                      { "id": "status", "label": "Status", "sortable": true, "format": "status" },
                      { "id": "deviceType", "label": "Type" },
                      { "id": "protocolType", "label": "Protocol", "format": "protocol" },
                      { "id": "lastHeartbeat", "label": "Last Seen", "sortable": true, "format": "datetime" }
                    ],
                    "sortColumn": "name",
                    "sortOrder": "asc",
                    "page": 1,
                    "pageSize": 10,
                    "total": 50,
                    "selectable": true,
                    "selectionMode": "multi"
                  }
                }
              ]
            }
          }
        }
      ]
    },
    {
      "id": "DataChart",
      "name": "Data Chart",
      "description": "Time-series data visualization component for sensor readings. Supports multiple series, time range selection, and real-time updates.",
      "category": "display",
      "properties": {
        "deviceId": {
          "type": "string",
          "required": true,
          "description": "Device ID"
        },
        "propertyName": {
          "type": "string",
          "required": true,
          "description": "Primary property to chart"
        },
        "series": {
          "type": "array",
          "required": false,
          "default": [],
          "items": {
            "id": "string",
            "deviceId": "string?",
            "propertyName": "string",
            "label": "string?",
            "color": "string?",
            "yAxis": "string?"
          },
          "description": "Additional series configuration"
        },
        "timeRange": {
          "type": "enum",
          "required": false,
          "values": ["5m", "15m", "30m", "1h", "6h", "24h", "7d", "custom"],
          "default": "1h",
          "description": "Time range preset"
        },
        "startTime": {
          "type": "string",
          "required": false,
          "format": "iso8601",
          "description": "Custom start time"
        },
        "endTime": {
          "type": "string",
          "required": false,
          "format": "iso8601",
          "description": "Custom end time"
        },
        "refreshInterval": {
          "type": "number",
          "required": false,
          "default": 0,
          "description": "Auto-refresh interval in ms, 0 = disabled"
        },
        "showLegend": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Show legend"
        },
        "showGrid": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Show grid lines"
        },
        "showTooltip": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Show data point tooltip"
        },
        "chartType": {
          "type": "enum",
          "required": false,
          "values": ["line", "area", "bar"],
          "default": "line",
          "description": "Chart type"
        },
        "unit": {
          "type": "string",
          "required": false,
          "description": "Y-axis unit"
        },
        "minValue": {
          "type": "number",
          "required": false,
          "description": "Y-axis minimum"
        },
        "maxValue": {
          "type": "number",
          "required": false,
          "description": "Y-axis maximum"
        },
        "height": {
          "type": "string",
          "required": false,
          "default": "300px",
          "description": "Chart height"
        }
      },
      "events": {
        "onTimeRangeChange": {
          "payload": "{ timeRange: string, startTime: string, endTime: string }",
          "description": "Time range changed"
        },
        "onDataPointClick": {
          "payload": "{ deviceId: string, property: string, timestamp: string, value: number }",
          "description": "Data point clicked"
        },
        "onExport": {
          "payload": "{ format: string, data: object }",
          "description": "Data export requested"
        },
        "onRefresh": {
          "payload": "{ deviceId: string, property: string }",
          "description": "Manual refresh"
        }
      },
      "dataBinding": {
        "type": "DataChartData",
        "schema": {
          "deviceId": "string",
          "propertyName": "string",
          "dataPoints": "{ timestamp: string, value: number }[]",
          "series": "ChartSeries[]",
          "timeRange": {
            "start": "string",
            "end": "string",
            "label": "string"
          },
          "statistics": {
            "min": "number",
            "max": "number",
            "avg": "number",
            "count": "number"
          }
        }
      },
      "examples": [
        {
          "title": "Temperature Time Series",
          "json": {
            "type": "updateComponents",
            "payload": {
              "surfaceId": "device-detail",
              "components": [
                {
                  "id": "chart-001",
                  "type": "DataChart",
                  "props": {
                    "deviceId": "dev-abc123",
                    "propertyName": "temperature",
                    "series": [
                      {
                        "id": "temp-series",
                        "propertyName": "temperature",
                        "label": "Temperature",
                        "color": "#3b82f6",
                        "yAxis": "left"
                      }
                    ],
                    "timeRange": "1h",
                    "refreshInterval": 5000,
                    "showLegend": true,
                    "showGrid": true,
                    "chartType": "line",
                    "unit": "C",
                    "minValue": -20,
                    "maxValue": 100
                  }
                }
              ]
            }
          }
        }
      ]
    },
    {
      "id": "ControlPanel",
      "name": "Control Panel",
      "description": "Device control widget for actuators. Provides ON/OFF toggles, value sliders, and command buttons with loading states.",
      "category": "control",
      "properties": {
        "deviceId": {
          "type": "string",
          "required": true,
          "description": "Device ID"
        },
        "commands": {
          "type": "array",
          "required": true,
          "items": {
            "id": "string",
            "name": "string",
            "displayName": "string?",
            "description": "string?",
            "type": "string",
            "parameters": "object[]?",
            "confirmRequired": "boolean?",
            "icon": "string?"
          },
          "description": "Available commands"
        },
        "properties": {
          "type": "array",
          "required": false,
          "default": [],
          "items": {
            "name": "string",
            "displayName": "string?",
            "dataType": "string",
            "currentValue": "any?",
            "unit": "string?",
            "min": "number?",
            "max": "number?",
            "step": "number?",
            "options": "object[]?"
          },
          "description": "Writable properties"
        },
        "loading": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Command executing"
        },
        "loadingCommand": {
          "type": "string",
          "required": false,
          "description": "Currently executing command ID"
        },
        "disabled": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Disable all controls"
        },
        "layout": {
          "type": "enum",
          "required": false,
          "values": ["vertical", "horizontal"],
          "default": "vertical",
          "description": "Control layout direction"
        },
        "deviceOnline": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Device online status"
        }
      },
      "events": {
        "onCommand": {
          "payload": "{ deviceId: string, command: string, parameters?: object }",
          "description": "Command executed"
        },
        "onPropertyChange": {
          "payload": "{ deviceId: string, property: string, value: any }",
          "description": "Property value changed"
        },
        "onPropertyCommit": {
          "payload": "{ deviceId: string, property: string, value: any }",
          "description": "Property change confirmed"
        },
        "onCancel": {
          "payload": "{ deviceId: string, command: string }",
          "description": "Cancel ongoing command"
        }
      },
      "dataBinding": {
        "type": "ControlPanelData",
        "schema": {
          "device": {
            "id": "string",
            "name": "string",
            "isOnline": "boolean"
          },
          "commands": "ControlCommand[]",
          "properties": "ControlProperty[]",
          "execution": {
            "loading": "boolean",
            "currentCommand": "string?",
            "lastResult": {
              "success": "boolean",
              "message": "string"
            }
          }
        }
      },
      "examples": [
        {
          "title": "Actuator Control with Toggle and Slider",
          "json": {
            "type": "updateComponents",
            "payload": {
              "surfaceId": "device-control",
              "components": [
                {
                  "id": "control-001",
                  "type": "ControlPanel",
                  "props": {
                    "deviceId": "dev-actuator-01",
                    "commands": [
                      {
                        "id": "turn_on",
                        "name": "turn_on",
                        "displayName": "Turn On",
                        "type": "button",
                        "icon": "power"
                      },
                      {
                        "id": "turn_off",
                        "name": "turn_off",
                        "displayName": "Turn Off",
                        "type": "button",
                        "icon": "power"
                      },
                      {
                        "id": "set_speed",
                        "name": "set_speed",
                        "displayName": "Fan Speed",
                        "type": "slider",
                        "parameters": [
                          { "name": "speed", "type": "number", "min": 0, "max": 100, "default": 50 }
                        ]
                      }
                    ],
                    "properties": [
                      {
                        "name": "speed",
                        "displayName": "Fan Speed",
                        "dataType": "number",
                        "currentValue": 50,
                        "unit": "%",
                        "min": 0,
                        "max": 100,
                        "step": 5
                      }
                    ],
                    "loading": false,
                    "layout": "vertical"
                  }
                }
              ]
            }
          }
        }
      ]
    },
    {
      "id": "ConfirmationDialog",
      "name": "Confirmation Dialog",
      "description": "Action confirmation dialog with danger level styling, auto-timeout option, and customizable buttons.",
      "category": "feedback",
      "properties": {
        "id": {
          "type": "string",
          "required": true,
          "description": "Dialog ID"
        },
        "title": {
          "type": "string",
          "required": true,
          "description": "Dialog title"
        },
        "message": {
          "type": "string",
          "required": true,
          "description": "Confirmation message"
        },
        "dangerLevel": {
          "type": "enum",
          "required": false,
          "values": ["normal", "warning", "destructive"],
          "default": "normal",
          "description": "Danger level affects styling"
        },
        "confirmText": {
          "type": "string",
          "required": false,
          "default": "Confirm",
          "description": "Confirm button text"
        },
        "cancelText": {
          "type": "string",
          "required": false,
          "default": "Cancel",
          "description": "Cancel button text"
        },
        "timeout": {
          "type": "number",
          "required": false,
          "default": 0,
          "description": "Auto-close timeout in ms, 0 = no timeout"
        },
        "showIcon": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Show danger/warning icon"
        },
        "loading": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Confirm button loading state"
        },
        "visible": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Dialog visibility"
        }
      },
      "events": {
        "onConfirm": {
          "payload": "{ dialogId: string }",
          "description": "Confirm button clicked"
        },
        "onCancel": {
          "payload": "{ dialogId: string }",
          "description": "Cancel button clicked"
        },
        "onTimeout": {
          "payload": "{ dialogId: string }",
          "description": "Dialog timed out"
        },
        "onClose": {
          "payload": "{ dialogId: string }",
          "description": "Dialog closed (any reason)"
        }
      },
      "dataBinding": {
        "type": "ConfirmationDialogData",
        "schema": {
          "id": "string",
          "title": "string",
          "message": "string",
          "dangerLevel": "'normal' | 'warning' | 'destructive'",
          "confirmText": "string",
          "cancelText": "string",
          "timeout": "number",
          "loading": "boolean"
        }
      },
      "examples": [
        {
          "title": "Destructive Action Confirmation",
          "json": {
            "type": "updateComponents",
            "payload": {
              "surfaceId": "modal-layer",
              "components": [
                {
                  "id": "confirm-delete",
                  "type": "ConfirmationDialog",
                  "props": {
                    "id": "confirm-delete",
                    "title": "Delete Device",
                    "message": "Are you sure you want to delete this device? This action cannot be undone.",
                    "dangerLevel": "destructive",
                    "confirmText": "Delete",
                    "cancelText": "Keep",
                    "timeout": 0,
                    "showIcon": true
                  }
                }
              ]
            }
          }
        }
      ]
    },
    {
      "id": "ProgressIndicator",
      "name": "Progress Indicator",
      "description": "Batch operation progress display with percentage, status text, and cancel option.",
      "category": "feedback",
      "properties": {
        "id": {
          "type": "string",
          "required": true,
          "description": "Progress ID"
        },
        "label": {
          "type": "string",
          "required": true,
          "description": "Operation label"
        },
        "progress": {
          "type": "number",
          "required": true,
          "min": 0,
          "max": 100,
          "description": "Progress percentage (0-100)"
        },
        "status": {
          "type": "string",
          "required": false,
          "description": "Status text"
        },
        "current": {
          "type": "number",
          "required": false,
          "default": 0,
          "description": "Current item count"
        },
        "total": {
          "type": "number",
          "required": false,
          "default": 0,
          "description": "Total item count"
        },
        "showPercentage": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Show percentage"
        },
        "showCancel": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Show cancel button"
        },
        "indeterminate": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Indeterminate progress"
        },
        "variant": {
          "type": "enum",
          "required": false,
          "values": ["default", "success", "error"],
          "default": "default",
          "description": "Progress variant"
        },
        "visible": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Visibility"
        }
      },
      "events": {
        "onCancel": {
          "payload": "{ progressId: string }",
          "description": "Cancel button clicked"
        },
        "onComplete": {
          "payload": "{ progressId: string }",
          "description": "Progress completed"
        },
        "onRetry": {
          "payload": "{ progressId: string }",
          "description": "Retry button clicked"
        }
      },
      "dataBinding": {
        "type": "ProgressIndicatorData",
        "schema": {
          "id": "string",
