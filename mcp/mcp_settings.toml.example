# TinyIoTHub MCP Server 配置
# 
# 使用方式：
# 1. 环境变量（推荐）
#    export TINYIOTHUB_API_URL=http://localhost:3002
#    export TINYIOTHUB_API_KEY=your-api-key
#
# 2. 配置文件
#    将此文件复制为 mcp_settings.toml

[mcp]
name = "tinyiothub"
version = "1.0.0"

# TinyIoTHub API 连接配置
[tinyiothub]
# API 服务器地址
api_url = "http://localhost:3002"

# API 认证密钥（建议使用环境变量 TINYIOTHUB_API_KEY）
# api_key = "your-api-key-here"

[logging]
level = "info"
