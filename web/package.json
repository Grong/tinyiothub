    "signal-utils": "^0.21.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.10.5",
    "@vitest/browser": "^4.0.18",
    "eslint": "^9.18.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
