# API Configuration
NEXT_PUBLIC_API_PREFIX=http://localhost:8080/api/v1
NEXT_PUBLIC_PUBLIC_API_PREFIX=http://localhost:8080/api/v1

# Application Configuration
NEXT_PUBLIC_EDITION=SELF_HOSTED
NEXT_PUBLIC_SITE_ABOUT=TinyIoTHub Management System
NEXT_PUBLIC_WEB_PREFIX=http://localhost:3000

# Security
NEXT_PUBLIC_CSP_WHITELIST=
NEXT_PUBLIC_ALLOW_EMBED=false

# Development
NODE_ENV=development
PORT=3000

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Marketplace API (uses fallback if not set)
NEXT_PUBLIC_MARKETPLACE_API_PREFIX=https://marketplace.tinyiothub.com/api/v1

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=