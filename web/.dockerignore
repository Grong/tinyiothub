# ============================================
# 前端专用 .dockerignore
# 构建上下文：web/ 目录
# ============================================

# 本地开发文件
node_modules/
.next/
out/
.turbo/
.pnpm-store/

# 测试和覆盖率
coverage/
.nyc_output/
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# 环境变量
.env
.env.local
.env.*.local
!.env.example

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统
.DS_Store
Thumbs.db
*.tmp

# Git
.git/
.gitignore
.gitattributes

# 文档
*.md
!README.md

# 构建配置（保留必要的）
# 注意：package.json, pnpm-lock.yaml, next.config.js 等需要保留
